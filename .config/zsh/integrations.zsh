#-------------------------------------------------------------------------------
# fzf
#-------------------------------------------------------------------------------

source <(fzf --zsh)

export FZF_CTRL_R_OPTS="
  --border
  --exact
  --height 14
  --layout reverse
"

#-------------------------------------------------------------------------------
# mise
#-------------------------------------------------------------------------------

eval "$(mise activate zsh)"

#-------------------------------------------------------------------------------
# OrbStack
#-------------------------------------------------------------------------------

source ~/.orbstack/shell/init.zsh 2>/dev/null || :
