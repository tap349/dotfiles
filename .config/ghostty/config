#------------------------------------------------------------------------------
# Colors
#------------------------------------------------------------------------------

background = #1C1B28
minimum-contrast = 1.5

search-background = #333300
search-foreground = yellow
search-selected-background = #FFFFAF
search-selected-foreground = black

#------------------------------------------------------------------------------
# Cursor
#------------------------------------------------------------------------------

#cursor-color = #D4E0FF
cursor-color = #76F59C
cursor-style = block

#cursor-color = green
#cursor-style = bar
#adjust-cursor-thickness = 2

shell-integration-features = no-cursor

#------------------------------------------------------------------------------
# Font
#------------------------------------------------------------------------------

font-family = JetBrains Mono NL Light
font-size = 15
font-style-bold = light

adjust-cell-height = 14%

#------------------------------------------------------------------------------
# Keybindings
#------------------------------------------------------------------------------

# For Emacs keybindings to work
macos-option-as-alt = true

#------------------------------------------------------------------------------
# Tabs
#------------------------------------------------------------------------------

window-new-tab-position = end

#------------------------------------------------------------------------------
# Window
#------------------------------------------------------------------------------

macos-window-shadow = false
window-padding-x = 6

#------------------------------------------------------------------------------
# Working directory
#------------------------------------------------------------------------------

tab-inherit-working-directory = false
window-inherit-working-directory = false
working-directory = home

#------------------------------------------------------------------------------
# Behaviour
#------------------------------------------------------------------------------

confirm-close-surface = false
copy-on-select = clipboard
quit-after-last-window-closed = true
